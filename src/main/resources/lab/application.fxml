<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lab.GameController">
    <center>
        <StackPane BorderPane.alignment="CENTER">
            <Canvas fx:id="canvas" height="400.0" width="800.0" />

            <StackPane fx:id="introOverlay" pickOnBounds="true" style="-fx-background-color: rgba(0,0,0,0.55);" visible="true">
                <VBox alignment="CENTER" spacing="14" StackPane.alignment="CENTER">
                    <Label style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" text="Kid Grid" />
                    <Button focusTraversable="false" onAction="#onStart" style="-fx-font-size: 16px; -fx-padding: 8 16;" text="Start" />
                </VBox>
                <padding>
                    <Insets bottom="12" left="12" right="12" top="12" />
                </padding>
            </StackPane>
        </StackPane>
    </center>
</BorderPane>
